# =============================================================================
#  Urbizen — modèle de configuration
#
#  Copier ce fichier en `.env` puis renseigner les valeurs réelles :
#      cp .env.example .env
#
#  `.env` est ignoré par Git et ne doit JAMAIS être versionné.
#  Ce fichier-ci ne contient que des noms de variables et des exemples
#  fictifs : aucune valeur réelle, aucun identifiant, aucune clé.
#
#  Toute variable lue par le code doit être documentée ici (CLAUDE.md, règle 7).
# =============================================================================


# -----------------------------------------------------------------------------
#  Microservice Python — backend/dp-service
# -----------------------------------------------------------------------------

# Chemins des Cerfa officiels à télécharger sur service-public.gouv.fr.
# Ces PDF ne sont pas versionnés. Chemins relatifs au dossier dp-service.
CERFA_DP=cerfa_16702-02.pdf
CERFA_PCMI=cerfa_13406-16.pdf

# Répertoire de sortie des dossiers PDF produits.
# Contient des données personnelles : le placer hors du dépôt et hors racine web.
DOSSIER_DIR=dossiers

# Domaine autorisé à appeler l'API (CORS).
# En production, indiquer le domaine exact — ne jamais laisser « * ».
ALLOW_ORIGIN=https://exemple.test


# -----------------------------------------------------------------------------
#  Notification par e-mail (facultatif)
#
#  Si NOTIFY_TO est vide, aucune notification n'est envoyée et les quatre
#  variables SMTP sont inutiles. Si NOTIFY_TO est renseigné, SMTP_USER et
#  SMTP_PASS deviennent obligatoires : leur absence interrompt l'envoi.
# -----------------------------------------------------------------------------

# Destinataire des notifications de nouveau dossier.
NOTIFY_TO=

# Serveur d'envoi.
SMTP_HOST=localhost
SMTP_PORT=587

# Identifiants SMTP. SMTP_USER sert aussi d'expéditeur du message.
# Ne jamais renseigner ces valeurs ici : uniquement dans le `.env` local.
SMTP_USER=
SMTP_PASS=
