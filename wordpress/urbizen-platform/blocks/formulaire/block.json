{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "urbizen/formulaire",
	"version": "0.9.0",
	"title": "Formulaire Urbizen",
	"category": "widgets",
	"icon": "feedback",
	"description": "Formulaire Urbizen. Reprend la localisation confirmée par le composant cadastre. En version 0.4.0, la validation est locale : rien n’est transmis à un serveur.",
	"keywords": [ "formulaire", "urbanisme", "localisation", "cadastre", "parcelle" ],
	"textdomain": "urbizen-platform",
	"supports": {
		"html": false,
		"multiple": true,
		"reusable": true,
		"anchor": true
	},
	"attributes": {
		"formType": {
			"type": "string",
			"default": "localisation"
		},
		"storageKey": {
			"type": "string",
			"default": "parcel"
		},
		"formId": {
			"type": "string",
			"default": ""
		}
	},
	"editorScript": "urbizen-form-editor",
	"editorStyle": "urbizen-form-editor"
}
